# Application
APP_ENV=dev
PORT=3000
API_PREFIX=api

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=root
MONGO_PASS=change-me
MONGO_DB_PROD=story_prod
MONGO_DB_DEV=story_dev
MONGO_RS=rs0
MONGO_AUTH_SOURCE=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES=30d

# AWS S3
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=story-app-assets

# Grok API (xAI)
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1

# OneSignal (push notifications)
ONESIGNAL_APP_ID=fc4ddaeb-7f81-4fc1-8e2d-70ee8be119fd
ONESIGNAL_REST_API_KEY=

# RevenueCat
REVENUECAT_WEBHOOK_AUTH=

# Admin (API x-admin-secret guard için — mobil admin endpoint'leri)
ADMIN_SECRET=change-me-admin-secret

# Admin Panel (/panel web UI)
# Admin kullanıcıları ve şifreleri DB'de (admin_users koleksiyonu) saklanır — env'den OKUNMAZ.
# İlk boot'ta admin_users boşsa kod içindeki sabit default (admin / Dede21erot_*) ile seed edilir;
# giriş yaptıktan sonra şifreyi panelden değiştir.
# SESSION_SECRET opsiyoneldir: tanımlı değilse ilk açılışta 64-char rastgele değer üretilip .env'e yazılır.
# SESSION_SECRET=

# Panel idle auto-logout süresi (ms). Default 10 dakika.
IDLE_TIMEOUT_MS=600000

# Panel login rate limiting (brute-force koruması, CC-04)
# PANEL_RATE_LIMIT_MAX: Window başına izin verilen başarısız login denemesi (default 5).
# PANEL_RATE_LIMIT_WINDOW_MS: Pencere süresi (ms, default 900000 = 15 dk).
PANEL_RATE_LIMIT_MAX=5
PANEL_RATE_LIMIT_WINDOW_MS=900000

# Audit Log (admin_audit_logs koleksiyonu için TTL süresi — gün cinsinden)
# Yoksa default 365 gün. Schema yüklendiğinde createdAt üstünde TTL index oluşturulur.
AUDIT_TTL_DAYS=365

# CORS
CORS_ORIGIN=*

# Socket.IO
SOCKET_ALLOWED_ORIGINS=*
