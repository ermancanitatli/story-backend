# Server
PORT=3000
API_PREFIX=api
CORS_ORIGIN=*
NODE_ENV=development
APP_ENV=development

# MongoDB
# MONGODB_URI set edilirse diğer MONGO_* alanları görmezden gelinir.
MONGODB_URI=
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=root
MONGO_PASS=change-me
MONGO_DB_PROD=story_prod
MONGO_DB_DEV=story_dev
MONGO_RS=rs0
MONGO_AUTH_SOURCE=admin
MONGO_DIRECT_CONNECTION=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES=30d

# AWS S3
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=story-app-assets

# Grok API (xAI)
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1

# Notifications (OneSignal)
ONESIGNAL_APP_ID=fc4ddaeb-7f81-4fc1-8e2d-70ee8be119fd
ONESIGNAL_REST_API_KEY=

# RevenueCat
REVENUECAT_WEBHOOK_AUTH=

# Admin (API x-admin-secret guard için — mobil admin endpoint'leri)
ADMIN_SECRET=change-me-admin-secret

# Admin Panel (/panel web UI)
# Admin kullanıcıları ve şifreleri DB'de (admin_users koleksiyonu) saklanır — env'den OKUNMAZ.
# İlk boot'ta admin_users boşsa kod içindeki sabit default (admin / Dede21erot_*) ile seed edilir;
# giriş yaptıktan sonra şifreyi panelden değiştir.

# Session
# SESSION_SECRET opsiyonel: tanımlı değilse ilk açılışta 64-char rastgele değer üretilip .env'e yazılır.
# Production'da rotate edilirse mevcut tüm session'lar invalide olur.
SESSION_SECRET=
IDLE_TIMEOUT_MS=600000

# Rate limit (panel login brute-force koruması, CC-04)
PANEL_RATE_LIMIT_MAX=5
PANEL_RATE_LIMIT_WINDOW_MS=900000

# Audit (admin_audit_logs TTL — gün cinsinden; schema yüklendiğinde createdAt üstünde TTL index oluşturulur)
AUDIT_TTL_DAYS=365

# Socket.IO
SOCKET_ALLOWED_ORIGINS=*

# Sentry (opsiyonel) — DSN boşsa entegrasyon devre dışı kalır.
# SENTRY_DSN: Backend (Node) SDK DSN'si.
# SENTRY_DSN_CLIENT: Panel browser SDK DSN'si (layout.ejs içinde conditional inject).
# SENTRY_TRACES_SAMPLE_RATE: 0.0–1.0, default 0.1.
# SENTRY_PROFILES_SAMPLE_RATE: 0.0–1.0, default 0.0.
SENTRY_DSN=
SENTRY_DSN_CLIENT=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Feature flags
# PANEL_PAGE_VIEW_ENABLED (CC-18): True ise admin panel GET istekleri
# admin_page_views koleksiyonuna yazılır (90 gün TTL).
PANEL_PAGE_VIEW_ENABLED=false
