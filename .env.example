# Application
APP_ENV=dev
PORT=3000
API_PREFIX=api

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=root
MONGO_PASS=change-me
MONGO_DB_PROD=story_prod
MONGO_DB_DEV=story_dev
MONGO_RS=rs0
MONGO_AUTH_SOURCE=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES=30d

# AWS S3
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=story-app-assets

# Grok API (xAI)
GROK_API_KEY=
GROK_API_URL=https://api.x.ai/v1

# OneSignal
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# RevenueCat
REVENUECAT_WEBHOOK_AUTH=

# Admin (API x-admin-secret guard için — mobil admin endpoint'leri)
ADMIN_SECRET=change-me-admin-secret

# Admin Panel (/panel web UI)
# Aşağıdaki iki değişken yalnızca admin_users koleksiyonu BOŞ iken ilk admin'i seed etmek için kullanılır.
# Seed tamamlandıktan sonra env'den silebilirsin; sonraki kullanıcılar panel üzerinden yönetilir.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-run

# SESSION_SECRET opsiyoneldir: tanımlı değilse uygulama ilk açılışta 64-karakter rastgele değer
# üretir ve .env dosyasına yazar. Prod'da önceden set etmek istersen aşağıdaki satırı aç:
# SESSION_SECRET=

# CORS
CORS_ORIGIN=*

# Socket.IO
SOCKET_ALLOWED_ORIGINS=*
