<% layout('panel/layout') %>

<div class="flex flex-col gap-5">
  <div class="kt-card">
    <div class="kt-card-content p-6">
      <h2 class="text-xl font-semibold text-mono mb-2">Merhaba, <%= typeof username !== 'undefined' ? username : 'Admin' %>!</h2>
      <p class="text-sm text-secondary-foreground">Story Admin Panel'e hoş geldin.</p>
    </div>
  </div>

  <!-- Quick links grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <% [
      {href:'/panel/users', icon:'ki-people', label:'Kullanıcılar', desc:'Kullanıcıları yönet'},
      {href:'/panel/stories', icon:'ki-book', label:'Hikayeler', desc:'Hikayeleri düzenle'},
      {href:'/panel/notifications', icon:'ki-notification-bing', label:'Bildirimler', desc:'Push bildirim gönder'},
      {href:'/panel/audit', icon:'ki-shield-tick', label:'Audit Log', desc:'İşlem geçmişi'}
    ].forEach(item => { %>
      <a href="<%= item.href %>" class="kt-card hover:border-primary transition-colors">
        <div class="kt-card-content p-5 flex items-start gap-4">
          <div class="flex items-center justify-center size-11 rounded-lg bg-primary/10 text-primary shrink-0">
            <i class="ki-filled <%= item.icon %> text-xl"></i>
          </div>
          <div>
            <h3 class="text-base font-semibold text-mono"><%= item.label %></h3>
            <p class="text-xs text-secondary-foreground mt-0.5"><%= item.desc %></p>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</div>
