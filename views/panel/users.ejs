<% layout('panel/layout') %>

<div class="flex flex-col gap-5">
  <!-- Filter bar -->
  <div class="kt-card">
    <div class="kt-card-content p-5">
      <div class="flex flex-wrap items-center gap-3">
        <input id="search-input" type="search" class="kt-input max-w-xs" placeholder="Handle, isim, email ara..."/>
        <select id="premium-filter" class="kt-input">
          <option value="">Tüm üyelik</option>
          <option value="true">Premium</option>
          <option value="false">Premium değil</option>
        </select>
        <select id="status-filter" class="kt-input">
          <option value="">Tüm durum</option>
          <option value="banned">Banlı</option>
          <option value="deleted">Silinmiş</option>
        </select>
        <button id="clear-filters" class="kt-btn kt-btn-outline">Temizle</button>
      </div>
    </div>
  </div>

  <!-- Users table -->
  <div class="kt-card">
    <div class="kt-card-content p-0">
      <table class="kt-table w-full">
        <thead>
          <tr>
            <th data-sortable="userHandle">Avatar / Handle</th>
            <th data-sortable="displayName">Display Name</th>
            <th data-sortable="email">Email</th>
            <th data-sortable="isPremium">Plan</th>
            <th data-sortable="createdAt">Oluşturma</th>
            <th data-sortable="lastSeen">Son Giriş</th>
            <th data-sortable="isBanned">Durum</th>
            <th class="text-end">Aksiyon</th>
          </tr>
        </thead>
        <tbody id="users-tbody">
          <tr><td colspan="8" class="p-8 text-center text-muted-foreground">Yükleniyor...</td></tr>
        </tbody>
      </table>
      <div class="flex items-center justify-between p-4 border-t border-border">
        <span id="users-total" class="text-sm text-secondary-foreground">—</span>
        <div class="flex gap-2">
          <button id="users-prev" class="kt-btn kt-btn-sm kt-btn-outline">Önceki</button>
          <button id="users-next" class="kt-btn kt-btn-sm kt-btn-outline">Sonraki</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/panel-assets/js/users-table.js"></script>
