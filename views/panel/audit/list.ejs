<%- include('../partials/shell-header') %>
<%
  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  const actionOptions = [
    '', 'BAN', 'UNBAN', 'DELETE', 'UPDATE_USER', 'UPDATE_CREDITS',
    'UPDATE_PREMIUM', 'LOGIN', 'LOGOUT', 'PASSWORD_CHANGE', 'ROLE_CHANGE',
  ];
%>

<div class="flex flex-col gap-5">
  <!-- Filter card -->
  <div class="kt-card">
    <div class="kt-card-header">
      <h3 class="kt-card-title">Filtreler</h3>
      <div class="text-xs text-secondary-foreground">
        Kayıt: <span id="audit-total">—</span>
      </div>
    </div>
    <div class="kt-card-content">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
        <div class="flex flex-col gap-1">
          <label class="kt-form-label text-xs" for="action-filter">Action</label>
          <select id="action-filter" class="kt-input">
            <% actionOptions.forEach(function(a) { %>
              <option value="<%= a %>"><%= a || '— hepsi —' %></option>
            <% }); %>
          </select>
        </div>
        <div class="flex flex-col gap-1">
          <label class="kt-form-label text-xs" for="target-filter">Target User ID</label>
          <input id="target-filter" type="text" class="kt-input" placeholder="user _id" />
        </div>
        <div class="flex flex-col gap-1">
          <label class="kt-form-label text-xs" for="admin-filter">Admin ID</label>
          <input id="admin-filter" type="text" class="kt-input" placeholder="admin _id" />
        </div>
        <div class="flex items-end gap-2">
          <button id="clear-filters" class="kt-btn kt-btn-outline" type="button">
            <i class="ki-filled ki-cross-circle"></i>
            <span>Temizle</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Logs table -->
  <div class="kt-card">
    <div class="kt-card-header">
      <h3 class="kt-card-title">Audit Log</h3>
    </div>
    <div class="kt-card-content p-0 overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-muted/40 text-secondary-foreground">
          <tr>
            <th class="text-start px-4 py-2 font-medium">Zaman</th>
            <th class="text-start px-4 py-2 font-medium">Admin</th>
            <th class="text-start px-4 py-2 font-medium">Action</th>
            <th class="text-start px-4 py-2 font-medium">Resource</th>
            <th class="text-start px-4 py-2 font-medium">Target</th>
            <th class="text-start px-4 py-2 font-medium">IP</th>
            <th class="text-start px-4 py-2 font-medium">Reason / Meta</th>
          </tr>
        </thead>
        <tbody id="audit-tbody">
          <tr>
            <td colspan="7" class="px-4 py-8 text-center text-secondary-foreground">
              Yükleniyor…
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="kt-card-footer flex items-center justify-end gap-3 p-4 border-t border-border">
      <button id="load-more" class="kt-btn kt-btn-sm kt-btn-outline hidden" type="button">
        <i class="ki-filled ki-down"></i>
        <span>Daha fazla yükle</span>
      </button>
    </div>
  </div>
</div>

<script src="/panel-assets/js/audit-logs.js"></script>

<%- include('../partials/shell-footer') %>
