<%
  function escapeHtml(s) {
    if (s === null || s === undefined) return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }
  function actionBadgeClass(action) {
    switch (action) {
      case 'BAN':
      case 'DELETE':
      case 'ROLE_CHANGE':
        return 'kt-badge kt-badge-destructive';
      case 'UNBAN':
      case 'UPDATE_PREMIUM':
        return 'kt-badge kt-badge-success';
      case 'LOGIN':
      case 'LOGOUT':
        return 'kt-badge kt-badge-secondary';
      case 'PASSWORD_CHANGE':
        return 'kt-badge kt-badge-warning';
      default:
        return 'kt-badge kt-badge-primary';
    }
  }
  function fmtDate(d) {
    if (!d) return '-';
    try {
      const dt = new Date(d);
      return dt.toLocaleString('tr-TR', { hour12: false });
    } catch (e) {
      return String(d);
    }
  }

  const page = Math.floor(offset / limit) + 1;
  const totalPages = Math.max(1, Math.ceil((total || 0) / limit));
  const hasPrev = offset > 0;
  const hasNext = offset + limit < (total || 0);

  function buildQS(extra) {
    const params = new URLSearchParams();
    if (filter.action) params.set('action', filter.action);
    if (filter.targetUserId) params.set('targetUserId', filter.targetUserId);
    if (filter.adminId) params.set('adminId', filter.adminId);
    params.set('limit', String(limit));
    params.set('offset', String(Math.max(0, extra.offset)));
    return '?' + params.toString();
  }

  const actionOptions = [
    '', 'BAN', 'UNBAN', 'DELETE', 'UPDATE_USER', 'UPDATE_CREDITS',
    'UPDATE_PREMIUM', 'LOGIN', 'LOGOUT', 'PASSWORD_CHANGE', 'ROLE_CHANGE',
  ];
%>
<!DOCTYPE html>
<html class="h-full" data-kt-theme="true" data-kt-theme-mode="light" dir="ltr" lang="tr">
<head>
  <title>Audit Log — Story Admin</title>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <link rel="icon" type="image/png" sizes="32x32" href="/panel-assets/media/app/favicon-32x32.png" />
  <link rel="shortcut icon" href="/panel-assets/media/app/favicon.ico" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  <link rel="stylesheet" href="/panel-assets/vendors/keenicons/styles.bundle.css" />
  <link rel="stylesheet" href="/panel-assets/css/styles.css" />
</head>
<body class="antialiased flex h-full text-base text-foreground bg-background demo1 kt-sidebar-fixed kt-header-fixed">
  <script>
    const defaultThemeMode = 'light';
    let themeMode;
    if (document.documentElement) {
      if (localStorage.getItem('kt-theme')) {
        themeMode = localStorage.getItem('kt-theme');
      } else {
        themeMode = defaultThemeMode;
      }
      document.documentElement.classList.add(themeMode);
    }
  </script>

  <div class="flex grow">
    <%- include('../partials/sidebar', { currentPath: currentPath, username: username }) %>
    <div class="flex flex-col grow">
      <%- include('../partials/header', { title: title, breadcrumbs: breadcrumbs, username: username }) %>
      <main class="grow p-5 lg:p-7.5">
        <div class="flex flex-col gap-5">
          <!-- Filter card -->
          <div class="kt-card">
            <div class="kt-card-header">
              <h3 class="kt-card-title">Filtreler</h3>
              <div class="text-xs text-secondary-foreground">
                Toplam <strong><%= total %></strong> kayıt · Sayfa <strong><%= page %></strong> / <%= totalPages %>
              </div>
            </div>
            <div class="kt-card-content">
              <form method="get" action="/panel/audit" class="grid grid-cols-1 md:grid-cols-4 gap-3">
                <div class="flex flex-col gap-1">
                  <label class="kt-form-label text-xs">Action</label>
                  <select name="action" class="kt-input">
                    <% actionOptions.forEach(function(a) { %>
                      <option value="<%= a %>" <%= filter.action === a ? 'selected' : '' %>><%= a || '— hepsi —' %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="flex flex-col gap-1">
                  <label class="kt-form-label text-xs">Target User ID</label>
                  <input type="text" name="targetUserId" value="<%= escapeHtml(filter.targetUserId || '') %>" class="kt-input" placeholder="user _id" />
                </div>
                <div class="flex flex-col gap-1">
                  <label class="kt-form-label text-xs">Admin ID</label>
                  <input type="text" name="adminId" value="<%= escapeHtml(filter.adminId || '') %>" class="kt-input" placeholder="admin _id" />
                </div>
                <div class="flex items-end gap-2">
                  <input type="hidden" name="limit" value="<%= limit %>" />
                  <button type="submit" class="kt-btn kt-btn-primary">
                    <i class="ki-filled ki-filter"></i>
                    <span>Uygula</span>
                  </button>
                  <a href="/panel/audit" class="kt-btn kt-btn-outline">Temizle</a>
                </div>
              </form>
            </div>
          </div>

          <!-- Logs table -->
          <div class="kt-card">
            <div class="kt-card-header">
              <h3 class="kt-card-title">Audit Log</h3>
            </div>
            <div class="kt-card-content p-0 overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-muted/40 text-secondary-foreground">
                  <tr>
                    <th class="text-start px-4 py-2 font-medium">Zaman</th>
                    <th class="text-start px-4 py-2 font-medium">Admin</th>
                    <th class="text-start px-4 py-2 font-medium">Action</th>
                    <th class="text-start px-4 py-2 font-medium">Resource</th>
                    <th class="text-start px-4 py-2 font-medium">Target</th>
                    <th class="text-start px-4 py-2 font-medium">IP</th>
                    <th class="text-start px-4 py-2 font-medium">Reason / Meta</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!logs || logs.length === 0) { %>
                    <tr>
                      <td colspan="7" class="px-4 py-8 text-center text-secondary-foreground">
                        Kayıt bulunamadı.
                      </td>
                    </tr>
                  <% } else { %>
                    <% logs.forEach(function(log) { %>
                      <%
                        const meta = log.metadata || {};
                        const resource = log.resource || meta.resource || '-';
                        const ip = log.ip || meta.ip || '-';
                        const target = log.targetUserId || log.resourceId || meta.resourceId || '-';
                        const targetHandle = log.targetUserHandle ? ' (@' + log.targetUserHandle + ')' : '';
                      %>
                      <tr class="border-t border-border">
                        <td class="px-4 py-2 whitespace-nowrap text-xs text-secondary-foreground"><%= fmtDate(log.createdAt) %></td>
                        <td class="px-4 py-2">
                          <div class="flex flex-col">
                            <span class="font-medium text-mono"><%= escapeHtml(log.adminUsername || '-') %></span>
                            <span class="text-xs text-secondary-foreground"><%= escapeHtml(log.adminId || '') %></span>
                          </div>
                        </td>
                        <td class="px-4 py-2">
                          <span class="<%= actionBadgeClass(log.action) %>"><%= escapeHtml(log.action) %></span>
                        </td>
                        <td class="px-4 py-2 text-xs"><%= escapeHtml(resource) %></td>
                        <td class="px-4 py-2 text-xs">
                          <%= escapeHtml(target) %><%= escapeHtml(targetHandle) %>
                        </td>
                        <td class="px-4 py-2 text-xs text-secondary-foreground"><%= escapeHtml(ip) %></td>
                        <td class="px-4 py-2 text-xs max-w-[280px] truncate" title="<%= escapeHtml(JSON.stringify(meta)) %>">
                          <% if (log.reason) { %>
                            <div class="truncate"><%= escapeHtml(log.reason) %></div>
                          <% } %>
                          <% if (meta && Object.keys(meta).length > 0) { %>
                            <details class="mt-1">
                              <summary class="cursor-pointer text-primary">meta</summary>
                              <pre class="text-[10px] whitespace-pre-wrap mt-1"><%= escapeHtml(JSON.stringify(meta, null, 2)) %></pre>
                            </details>
                          <% } %>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>
            <div class="kt-card-footer flex items-center justify-between gap-3 p-4 border-t border-border">
              <div class="text-xs text-secondary-foreground">
                <%= offset + 1 %>–<%= Math.min(offset + limit, total) %> / <%= total %>
              </div>
              <div class="flex items-center gap-2">
                <% if (hasPrev) { %>
                  <a href="<%= buildQS({ offset: Math.max(0, offset - limit) }) %>" class="kt-btn kt-btn-outline kt-btn-sm">
                    <i class="ki-filled ki-left"></i>
                    <span>Önceki</span>
                  </a>
                <% } else { %>
                  <button class="kt-btn kt-btn-outline kt-btn-sm" disabled>
                    <i class="ki-filled ki-left"></i>
                    <span>Önceki</span>
                  </button>
                <% } %>
                <% if (hasNext) { %>
                  <a href="<%= buildQS({ offset: offset + limit }) %>" class="kt-btn kt-btn-outline kt-btn-sm">
                    <span>Sonraki</span>
                    <i class="ki-filled ki-right"></i>
                  </a>
                <% } else { %>
                  <button class="kt-btn kt-btn-outline kt-btn-sm" disabled>
                    <span>Sonraki</span>
                    <i class="ki-filled ki-right"></i>
                  </button>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </main>
      <%- include('../partials/footer') %>
    </div>
  </div>

  <script src="/panel-assets/js/core.bundle.js"></script>
  <script src="/panel-assets/vendors/ktui/ktui.min.js"></script>
</body>
</html>
