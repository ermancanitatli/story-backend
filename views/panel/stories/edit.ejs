<%- include('../partials/shell-header') %>
<div class="flex items-center justify-between mb-5">
  <h1 class="text-2xl font-semibold"><%= isNew ? 'Yeni Hikaye' : 'Hikaye Düzenle' %></h1>
  <div class="flex gap-2">
    <button id="cancel-btn" class="kt-btn kt-btn-outline" onclick="history.back()">İptal</button>
    <button id="draft-btn" class="kt-btn kt-btn-outline">Taslak Kaydet</button>
    <button id="save-btn" class="kt-btn kt-btn-primary">Kaydet</button>
  </div>
</div>

<div id="dirty-banner" class="hidden mb-4 px-4 py-2 rounded-md border border-warning/20 bg-warning/10 text-warning text-sm">
  Kaydedilmemiş değişiklikler var.
</div>

<div class="kt-card">
  <div class="kt-card-content p-0">
    <!-- Tabs -->
    <div class="flex border-b border-border" id="tabs">
      <button class="tab px-4 py-3 text-sm font-medium border-b-2 border-primary text-primary" data-tab="basic">Temel Bilgiler</button>
      <button class="tab px-4 py-3 text-sm font-medium text-muted-foreground" data-tab="content">İçerik</button>
      <button class="tab px-4 py-3 text-sm font-medium text-muted-foreground" data-tab="characters">Karakterler</button>
      <button class="tab px-4 py-3 text-sm font-medium text-muted-foreground" data-tab="images">Görseller</button>
      <button class="tab px-4 py-3 text-sm font-medium text-muted-foreground" data-tab="settings">Ayarlar</button>
    </div>

    <!-- Tab panels -->
    <div class="p-5">
      <div class="tab-panel" data-tab="basic">
        <div class="grid gap-5">
          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Dil</label>
            <select id="locale-select" class="kt-input max-w-xs">
              <% ['en','tr','ar','de','es','fr','it','ja','ko','pt','ru','zh'].forEach(l => { %>
                <option value="<%= l %>"><%= l.toUpperCase() %></option>
              <% }); %>
            </select>
          </div>

          <div id="locale-badges" class="flex flex-wrap gap-2"></div>

          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Başlık (<span class="locale-label">EN</span>)</label>
            <input id="f-title" class="kt-input" placeholder="Hikaye başlığı"/>
          </div>
          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Özet (<span class="locale-label">EN</span>)</label>
            <textarea id="f-summary" class="kt-input" rows="3" placeholder="Kısa özet"></textarea>
          </div>
          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Çocuk Dostu Özet (<span class="locale-label">EN</span>)</label>
            <textarea id="f-summary-safe" class="kt-input" rows="3" placeholder="Aile dostu versiyon"></textarea>
          </div>

          <div class="border-t border-border my-2"></div>

          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Tür</label>
            <input id="f-genre" class="kt-input"/>
          </div>
          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Zorluk</label>
            <select id="f-difficulty" class="kt-input">
              <option value="">—</option>
              <option value="easy">Kolay</option>
              <option value="medium">Orta</option>
              <option value="hard">Zor</option>
            </select>
          </div>
          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Yaş</label>
            <input id="f-age" class="kt-input"/>
          </div>
          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Kredi Maliyeti</label>
            <input id="f-credit-cost" type="number" min="0" class="kt-input"/>
          </div>

          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Yayın</label>
            <div class="flex items-center gap-5">
              <label class="kt-label flex items-center gap-2"><input id="f-is-paid" type="checkbox" class="kt-checkbox"/> <span class="kt-checkbox-label">Ücretli</span></label>
              <label class="kt-label flex items-center gap-2"><input id="f-is-published" type="checkbox" class="kt-checkbox"/> <span class="kt-checkbox-label">Yayınla</span></label>
            </div>
          </div>
        </div>
      </div>
      <div class="tab-panel hidden" data-tab="content">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-base font-semibold">Bölümler (Chapters)</h3>
          <button type="button" id="btn-add-chapter" class="kt-btn kt-btn-sm kt-btn-primary">+ Bölüm Ekle</button>
        </div>
        <div id="chapters-list" class="flex flex-col gap-3">
          <p class="text-sm text-muted-foreground" id="chapters-empty">Henüz bölüm eklenmedi.</p>
        </div>
      </div>
      <div class="tab-panel hidden" data-tab="characters">
        <p class="text-sm text-muted-foreground">Karakter yönetimi (STORY-13).</p>
      </div>
      <div class="tab-panel hidden" data-tab="images">
        <div class="flex flex-col gap-8">
          <!-- COVER -->
          <section>
            <h3 class="text-base font-semibold mb-3">Kapak Görseli</h3>
            <div id="cover-dropzone" class="border-2 border-dashed border-border rounded-md p-5 text-center cursor-pointer hover:bg-muted/30 max-w-md mx-auto">
              <div id="cover-preview" class="hidden">
                <img id="cover-img" class="max-h-60 max-w-full w-auto object-contain mx-auto rounded"/>
                <div class="mt-3 flex justify-center gap-2">
                  <button type="button" class="kt-btn kt-btn-sm kt-btn-outline" id="cover-replace">Değiştir</button>
                  <button type="button" class="kt-btn kt-btn-sm kt-btn-destructive" id="cover-remove">Kaldır</button>
                </div>
              </div>
              <div id="cover-placeholder">
                <i class="ki-filled ki-picture text-[48px] text-muted-foreground"></i>
                <p class="text-sm text-muted-foreground mt-2">Sürükle bırak veya tıkla</p>
                <p class="text-xs text-muted-foreground">JPG, PNG, WebP · Max 1920px · Otomatik WebP dönüşümü</p>
              </div>
              <input type="file" id="cover-input" accept="image/jpeg,image/png,image/webp" class="hidden"/>
            </div>
            <div id="cover-progress" class="hidden mt-2">
              <div class="kt-progress"><div class="kt-progress-bar" style="width:0%"></div></div>
            </div>
          </section>

          <section>
            <h3 class="text-base font-semibold mb-3">Bölüm Medyaları</h3>
            <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-5">
              <!-- LEFT: chapter list -->
              <div class="border border-border rounded-md overflow-hidden bg-card">
                <div class="px-4 py-2.5 border-b border-border bg-muted/30">
                  <span class="text-sm font-medium text-muted-foreground">Bölümler</span>
                </div>
                <ul id="chapter-list" class="flex flex-col divide-y divide-border max-h-[70vh] overflow-y-auto">
                  <!-- filled by JS -->
                </ul>
              </div>

              <!-- RIGHT: media grid for selected chapter -->
              <div class="flex flex-col">
                <div class="flex items-center justify-between gap-2 mb-3 flex-wrap">
                  <div class="flex items-center gap-2">
                    <h4 id="chapter-media-title" class="text-sm font-semibold text-foreground">Bir bölüm seçin</h4>
                  </div>
                  <div class="flex gap-1 kt-btn-group" role="tablist">
                    <button type="button" data-media-tab="images" class="media-tab kt-btn kt-btn-sm kt-btn-primary">
                      <i class="ki-filled ki-picture"></i>
                      Görseller (<span id="media-count-images">0</span>)
                    </button>
                    <button type="button" data-media-tab="videos" class="media-tab kt-btn kt-btn-sm kt-btn-outline">
                      <i class="ki-filled ki-video"></i>
                      Videolar (<span id="media-count-videos">0</span>)
                    </button>
                  </div>
                </div>
                <div id="gallery-dropzone" class="border-2 border-dashed border-border rounded-md p-4 mb-4 text-center cursor-pointer hover:bg-muted/30">
                  <i class="ki-filled ki-cloud-add text-[32px] text-muted-foreground"></i>
                  <p class="text-sm mt-2"><span id="upload-kind-label">Görseller</span> için sürükle-bırak veya tıkla</p>
                  <p class="text-xs text-muted-foreground">JPG, PNG, WebP · MP4, WebM · MOV</p>
                  <input type="file" id="gallery-input" accept="image/jpeg,image/png,image/webp,video/mp4,video/webm,video/quicktime" multiple class="hidden"/>
                </div>
                <div id="gallery-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3"></div>
                <p id="gallery-empty" class="hidden text-sm text-muted-foreground text-center py-10">Bu kategoride medya yok.</p>
              </div>
            </div>
          </section>

          <!-- Media detail modal -->
          <div id="media-modal" class="hidden fixed inset-0 z-50 bg-black/70 flex items-center justify-center p-4" role="dialog">
            <div class="bg-background border border-border rounded-lg max-w-3xl w-full flex flex-col" style="max-height:90vh;overflow:hidden;">
              <div class="flex items-center justify-between px-5 py-3 border-b border-border shrink-0">
                <h4 class="text-base font-semibold" id="media-modal-title">Medya Detayı</h4>
                <button type="button" id="media-modal-close" class="kt-btn kt-btn-icon kt-btn-ghost">
                  <i class="ki-filled ki-cross"></i>
                </button>
              </div>
              <div class="flex-1" style="overflow-y:auto;min-height:0;">
                <div id="media-modal-preview" class="bg-muted/20 flex items-center justify-center p-4"></div>
                <div class="p-5 grid gap-4">
                  <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                    <label class="kt-form-label max-w-56">URL</label>
                    <input id="media-modal-url" class="kt-input text-xs" readonly/>
                  </div>
                  <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                    <label class="kt-form-label max-w-56">Başlık</label>
                    <input id="media-modal-title-input" class="kt-input" placeholder="Opsiyonel başlık"/>
                  </div>
                  <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                    <label class="kt-form-label max-w-56">Alt Metin</label>
                    <input id="media-modal-alt" class="kt-input" placeholder="Alt / etiket"/>
                  </div>
                  <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                    <label class="kt-form-label max-w-56">Sıra (order)</label>
                    <input id="media-modal-order" type="number" class="kt-input"/>
                  </div>
                  <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                    <label class="kt-form-label max-w-56">Durum</label>
                    <label class="kt-label flex items-center gap-2">
                      <input type="checkbox" id="media-modal-hidden" class="kt-checkbox"/>
                      <span class="kt-checkbox-label">Gizli (client'ta gösterme)</span>
                    </label>
                  </div>
                </div>
              </div>
              <div class="flex items-center justify-between px-5 py-3 border-t border-border bg-muted/10 shrink-0">
                <button type="button" id="media-modal-delete" class="kt-btn kt-btn-sm kt-btn-destructive">
                  <i class="ki-filled ki-trash"></i> Sil
                </button>
                <div class="flex gap-2">
                  <button type="button" id="media-modal-cancel" class="kt-btn kt-btn-sm kt-btn-outline">İptal</button>
                  <button type="button" id="media-modal-save" class="kt-btn kt-btn-sm kt-btn-primary">Kaydet</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="tab-panel hidden" data-tab="settings">
        <div class="grid gap-5">
          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Etiketler</label>
            <div class="flex flex-col gap-1 flex-1">
              <div id="tags-wrapper" class="border border-border rounded-md p-2 flex flex-wrap gap-2 min-h-[42px]">
                <input id="tags-input" type="text" class="flex-1 min-w-[120px] outline-none text-sm bg-transparent" placeholder="Etiket yaz, Enter veya virgül"/>
              </div>
              <small class="text-xs text-muted-foreground">Enter veya virgül ile ekle.</small>
            </div>
          </div>

          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Firestore Legacy ID</label>
            <input id="f-legacy-id" class="kt-input bg-muted/30" readonly/>
          </div>

          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">SEO Başlık (EN)</label>
            <input id="f-meta-title" class="kt-input"/>
          </div>

          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">SEO Açıklama</label>
            <textarea id="f-meta-description" class="kt-input" rows="2"></textarea>
          </div>

          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Admin Notları (dahili)</label>
            <textarea id="f-internal-notes" class="kt-input" rows="3" placeholder="Sadece admin görür"></textarea>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/panel-assets/js/stories-edit.js"></script>
<script src="/panel-assets/js/stories-chapters.js"></script>
<script src="/panel-assets/js/stories-chapter-media.js"></script>

<%- include('../partials/shell-footer') %>
