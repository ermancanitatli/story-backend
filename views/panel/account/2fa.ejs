<%- include('../partials/shell-header') %>
<div class="max-w-md mx-auto">
  <div class="kt-card">
    <div class="kt-card-content p-6">
      <h2 class="text-xl font-semibold mb-4">İki Faktörlü Doğrulama</h2>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="kt-alert kt-alert-destructive flex items-center gap-2 px-3 py-2 rounded-md border border-destructive/20 bg-destructive/10 text-destructive text-sm mb-4">
          <i class="ki-filled ki-shield-cross"></i><span><%= error %></span>
        </div>
      <% } %>

      <% if (enabled) { %>
        <% if (justEnabled && recoveryCodes) { %>
          <div class="mb-4 p-3 border border-success/30 bg-success/10 rounded">
            <strong>2FA aktifleştirildi!</strong>
            <p class="mt-1 text-sm">Aşağıdaki kurtarma kodlarını güvenli bir yere kaydet (bir daha gösterilmez):</p>
            <ul class="mt-2 font-mono text-sm grid grid-cols-2 gap-1">
              <% recoveryCodes.forEach(function(c) { %><li><%= c %></li><% }); %>
            </ul>
          </div>
        <% } %>
        <p class="mb-4 flex items-center gap-2 text-sm">
          <i class="ki-filled ki-shield-tick text-success"></i>
          <span>2FA şu anda aktif.</span>
        </p>
        <form method="post" action="/panel/account/2fa/disable" class="grid gap-5">
          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Mevcut Şifre</label>
            <input type="password" name="password" class="kt-input" placeholder="Devre dışı bırakmak için şifreniz" required/>
          </div>
          <div class="flex justify-end">
            <button type="submit" class="kt-btn kt-btn-destructive">Devre Dışı Bırak</button>
          </div>
        </form>
      <% } else { %>
        <p class="mb-4 text-sm">Authenticator app (Google Authenticator, 1Password, Authy) ile QR kodu tarayın:</p>
        <% if (qrDataUrl) { %>
          <img src="<%= qrDataUrl %>" class="mx-auto mb-4" alt="TOTP QR" width="200" height="200"/>
        <% } %>
        <% if (pendingSecret) { %>
          <p class="text-xs text-center mb-4 font-mono break-all">Manuel: <%= pendingSecret %></p>
        <% } %>
        <form method="post" action="/panel/account/2fa/enable" class="grid gap-5">
          <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
            <label class="kt-form-label flex items-center gap-1 max-w-56">Doğrulama Kodu</label>
            <input type="text" name="code" class="kt-input" placeholder="000000" maxlength="6" pattern="[0-9]{6}" required autocomplete="off" inputmode="numeric"/>
          </div>
          <div class="flex justify-end">
            <button type="submit" class="kt-btn kt-btn-primary">Doğrula ve Aktifleştir</button>
          </div>
        </form>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/shell-footer') %>
