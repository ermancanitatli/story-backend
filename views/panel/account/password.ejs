<div class="max-w-md mx-auto">
  <div class="kt-card">
    <div class="kt-card-content p-6">
      <h2 class="text-xl font-semibold mb-4">Şifre Değiştir</h2>

      <% if (typeof forceChange !== 'undefined' && forceChange) { %>
        <div class="kt-alert kt-alert-warning flex items-center gap-2 px-3 py-2 rounded-md border border-warning/20 bg-warning/10 text-warning text-sm mb-4">
          <i class="ki-filled ki-information-5"></i>
          <span>Geçici şifre ile giriş yaptınız. Devam etmeden önce yeni bir şifre belirlemelisiniz.</span>
        </div>
      <% } %>

      <% if (error) { %>
        <div class="kt-alert kt-alert-destructive flex items-center gap-2 px-3 py-2 rounded-md border border-destructive/20 bg-destructive/10 text-destructive text-sm mb-4">
          <i class="ki-filled ki-shield-cross"></i><span><%= error %></span>
        </div>
      <% } %>

      <% if (success) { %>
        <div class="kt-alert kt-alert-success flex items-center gap-2 px-3 py-2 rounded-md border border-success/20 bg-success/10 text-success text-sm mb-4">
          <i class="ki-filled ki-shield-tick"></i><span><%= success %></span>
        </div>
      <% } %>

      <form method="post" action="/panel/account/password" class="flex flex-col gap-4">
        <div class="flex flex-col gap-1">
          <label class="kt-form-label">Mevcut Şifre</label>
          <input type="password" name="currentPassword" class="kt-input" required autofocus/>
        </div>
        <div class="flex flex-col gap-1">
          <label class="kt-form-label">Yeni Şifre</label>
          <input type="password" name="newPassword" class="kt-input" required/>
          <small class="text-xs text-muted-foreground">En az 12 karakter, 1 büyük harf, 1 rakam.</small>
        </div>
        <div class="flex flex-col gap-1">
          <label class="kt-form-label">Yeni Şifre Tekrar</label>
          <input type="password" name="confirmPassword" class="kt-input" required/>
        </div>
        <button type="submit" class="kt-btn kt-btn-primary">Şifreyi Değiştir</button>
      </form>
    </div>
  </div>
</div>
