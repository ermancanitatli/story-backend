<div id="user-edit-modal" class="hidden" style="position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.55);display:flex;align-items:center;justify-content:center;padding:16px;">
  <div class="kt-card" style="max-width:720px;width:100%;max-height:90vh;overflow-y:auto;background:#fff;border-radius:12px;box-shadow:0 20px 50px rgba(0,0,0,0.35);">
    <div class="kt-card-content p-0">
      <div class="flex items-center justify-between p-4 border-b border-border">
        <h3 class="text-lg font-semibold" id="modal-user-title">Kullanıcı Düzenle</h3>
        <button class="kt-btn kt-btn-icon kt-btn-ghost" onclick="window.closeUserEditModal()">
          <i class="ki-filled ki-cross"></i>
        </button>
      </div>

      <!-- Tabs -->
      <div class="flex border-b border-border" id="user-tabs">
        <button class="user-tab px-4 py-3 text-sm font-medium border-b-2 border-primary text-primary" data-tab="general">Genel</button>
        <button class="user-tab px-4 py-3 text-sm font-medium text-muted-foreground" data-tab="plan">Plan & Kredi</button>
        <button class="user-tab px-4 py-3 text-sm font-medium text-muted-foreground" data-tab="moderation">Moderasyon</button>
        <button class="user-tab px-4 py-3 text-sm font-medium text-muted-foreground" data-tab="relations">İlişkiler</button>
        <button class="user-tab px-4 py-3 text-sm font-medium text-muted-foreground" data-tab="stories">Hikayeler</button>
      </div>

      <div class="p-5">
        <!-- Genel -->
        <div class="user-panel" data-tab="general">
          <div class="grid gap-5">
            <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
              <label class="kt-form-label flex items-center gap-1 max-w-56" for="f-handle">Handle</label>
              <input id="f-handle" class="kt-input"/>
            </div>
            <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
              <label class="kt-form-label flex items-center gap-1 max-w-56" for="f-display">Display Name</label>
              <input id="f-display" class="kt-input"/>
            </div>
            <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
              <label class="kt-form-label flex items-center gap-1 max-w-56" for="f-email">Email</label>
              <input id="f-email" class="kt-input" type="email"/>
            </div>
          </div>
        </div>

        <!-- Plan & Kredi -->
        <div class="user-panel hidden" data-tab="plan">
          <div class="grid gap-5">
            <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
              <label class="kt-form-label flex items-center gap-1 max-w-56" for="f-premium">Premium</label>
              <div class="grow flex items-center">
                <input id="f-premium" type="checkbox" class="kt-checkbox"/>
              </div>
            </div>
            <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
              <label class="kt-form-label flex items-center gap-1 max-w-56" for="f-plan">Plan</label>
              <input id="f-plan" class="kt-input"/>
            </div>
            <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
              <label class="kt-form-label flex items-center gap-1 max-w-56" for="f-credits">Kredi</label>
              <input id="f-credits" type="number" class="kt-input"/>
            </div>
          </div>
        </div>

        <!-- Moderasyon -->
        <div class="user-panel hidden" data-tab="moderation">
          <div class="grid gap-5">
            <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
              <label class="kt-form-label flex items-center gap-1 max-w-56">Durum</label>
              <div class="grow">
                <span id="f-status" class="kt-badge kt-badge-outline">—</span>
              </div>
            </div>
            <div class="border border-border rounded-md p-4">
              <h4 class="font-semibold mb-4">Ban</h4>
              <div class="grid gap-5">
                <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                  <label class="kt-form-label flex items-center gap-1 max-w-56" for="f-ban-reason">Sebep</label>
                  <textarea id="f-ban-reason" rows="2" class="kt-input" placeholder="Ban sebebi"></textarea>
                </div>
                <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                  <label class="kt-form-label flex items-center gap-1 max-w-56" for="f-ban-until">Süre</label>
                  <div class="grow flex flex-col gap-1">
                    <input id="f-ban-until" type="datetime-local" class="kt-input"/>
                    <small class="text-xs text-muted-foreground">Boş bırakılırsa kalıcı ban uygulanır.</small>
                  </div>
                </div>
                <div class="flex justify-end gap-2">
                  <button class="kt-btn kt-btn-outline" id="btn-unban">Banı Kaldır</button>
                  <button class="kt-btn kt-btn-warning" id="btn-ban">Banla</button>
                </div>
              </div>
            </div>
            <div class="border border-destructive/30 rounded-md p-4 bg-destructive/5">
              <h4 class="font-semibold text-destructive mb-4">Tehlikeli: Kullanıcı Silme</h4>
              <div class="grid gap-5">
                <div class="flex items-baseline flex-wrap lg:flex-nowrap gap-2.5">
                  <label class="kt-form-label flex items-center gap-1 max-w-56" for="f-delete-confirm">Onay</label>
                  <div class="grow flex flex-col gap-1">
                    <input id="f-delete-confirm" class="kt-input" autocomplete="off" placeholder="SIL"/>
                    <small class="text-xs text-muted-foreground">Silmek için <strong>SIL</strong> yazın.</small>
                  </div>
                </div>
                <div class="flex justify-end">
                  <button class="kt-btn kt-btn-destructive" id="btn-delete" disabled>Kullanıcıyı Sil</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- İlişkiler -->
        <div class="user-panel hidden" data-tab="relations">
          <div class="text-sm">
            <p>Arkadaş sayısı: <strong id="f-friend-count">—</strong></p>
            <p>Toplam hikaye session: <strong id="f-story-count">—</strong></p>
          </div>
        </div>

        <!-- Hikayeler -->
        <div class="user-panel hidden" data-tab="stories">
          <div id="f-recent-sessions" class="text-sm"></div>
        </div>
      </div>

      <div class="flex items-center justify-end gap-2 p-4 border-t border-border">
        <button class="kt-btn kt-btn-outline" onclick="window.closeUserEditModal()">İptal</button>
        <button id="btn-save" class="kt-btn kt-btn-primary">Kaydet</button>
      </div>
    </div>
  </div>
</div>
